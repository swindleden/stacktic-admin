# ---------------------------------------------------------------------------
# Stacktic Backstage — .env.example
#
# Copy to `.env.local` (gitignored) and fill in values.
# ---------------------------------------------------------------------------

# --- Database ---
# Direct Postgres connection (port 5432, session pooler on Supabase).
# Backstage reads operator-side data — companies, audit events, jobs queue.
# Same gotchas as site-app: append `?sslmode=require&uselibpqcompat=true`.
DATABASE_URL_DIRECT=

# --- Auth.js v5 (Google SSO) ---
# Backstage requires authentication. Single provider: Google. Domain
# whitelist below restricts who can sign in.
#
# AUTH_SECRET — JWT signing key. Generate with:
#   openssl rand -base64 32
# Rotating logs everyone out (which is fine — Backstage has at most a
# handful of operators).
AUTH_SECRET=

# Google OAuth client. Create at:
#   Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# Authorized redirect URIs to add in the console:
#   http://localhost:3100/api/auth/callback/google     (dev)
#   https://<your-deployed-host>/api/auth/callback/google   (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Required when deployed behind a reverse proxy (Vercel, Cloudflare, etc.).
# Auth.js otherwise rejects the proxied Host header. Vercel sets this
# automatically for projects detected as next-auth, but explicit beats
# implicit when debugging.
AUTH_TRUST_HOST=true

# Comma-separated list of email domains allowed to sign in. Defaults to
# `stacktic.app` if unset, which is the right default for production.
# Override only if you need to add cofounders / contractors on a
# different domain (rare).
AUTH_ALLOWED_DOMAINS=stacktic.app
